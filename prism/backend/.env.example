# =============================================================================
# DefiLlama — NO API KEY
# =============================================================================
# Default public API is used for TVL, fees, bridges. Optional: change base URL.
# Docs: https://defillama.com/docs/api
DEFILLAMA_BASE_URL=https://api.llama.fi

# =============================================================================
# Snapshot — NO API KEY
# =============================================================================
# Public GraphQL endpoint for governance proposals / spaces.
# Override only if Snapshot moves endpoints.
SNAPSHOT_GRAPHQL_URL=https://hub.snapshot.org/graphql

# =============================================================================
# Chainlink (on-chain reads) — NO API KEY for Chainlink itself
# =============================================================================
# Reads price feeds via JSON-RPC. Default uses a public Ethereum RPC.
# For production, use YOUR keyed endpoint (Infura, Alchemy, QuickNode, etc.):
#   Infura:   https://mainnet.infura.io/v3/YOUR_PROJECT_ID
#   Alchemy:  https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   QuickNode: (dashboard URL they give you)
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# =============================================================================
# The Graph — API key REQUIRED for gateway subgraph IDs in protocols.json
# =============================================================================
# Create a key: https://thegraph.com/studio/apikeys/
# protocols.json uses bare deployment IDs; code builds:
#   https://gateway.thegraph.com/api/subgraphs/id/<ID>
# with Authorization: Bearer <THEGRAPH_API_KEY>
# If your key only works with the key in the URL path, set:
#   THEGRAPH_USE_KEY_IN_URL=1
THEGRAPH_API_KEY=
THEGRAPH_GATEWAY_BASE=https://gateway.thegraph.com
THEGRAPH_USE_KEY_IN_URL=

# =============================================================================
# Dune — optional (GET latest query results; key from https://dune.com/settings/api)
# =============================================================================
# Set DUNE_API_KEY, then add per-protocol query IDs in data/protocols.json:
#   dune_whale_query_id, dune_users_query_id, dune_liquidations_query_id
# Column names expected by the backend are documented in services/dune.py.
DUNE_API_KEY=
DUNE_BASE_URL=https://api.dune.com/api/v1

# =============================================================================
# News / narrative — CryptoPanic is optional (often paid). Default: FREE RSS.
# =============================================================================
# NEWS_PROVIDER: rss | gnews | cryptopanic
# If unset: tries GNews (if GNEWS_API_KEY), then CryptoPanic (if key), else RSS.
NEWS_PROVIDER=
# GNews free tier: https://gnews.io/
GNEWS_API_KEY=
GNEWS_BASE_URL=https://gnews.io/api/v4
# CryptoPanic (if you have a paid key): https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1

# =============================================================================
# Backend
# =============================================================================
CORS_ORIGINS=http://localhost:5173
CACHE_TTL_SECONDS=900
DATA_REFRESH_INTERVAL_MINUTES=15
