# DefiLlama — no key needed, public API
DEFILLAMA_BASE_URL=https://api.llama.fi

# Dune Analytics — free API key at dune.com
DUNE_API_KEY=your_dune_api_key_here
DUNE_BASE_URL=https://api.dune.com/api/v1

# The Graph — free API key at thegraph.com
THEGRAPH_API_KEY=your_thegraph_api_key_here

# Snapshot — no key needed, public GraphQL
SNAPSHOT_GRAPHQL_URL=https://hub.snapshot.org/graphql

# CryptoPanic — free API key at cryptopanic.com
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1

# Backend config
CORS_ORIGINS=http://localhost:5173
CACHE_TTL_SECONDS=900
DATA_REFRESH_INTERVAL_MINUTES=15
